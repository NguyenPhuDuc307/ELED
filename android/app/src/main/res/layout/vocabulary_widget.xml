<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="10dp"
    android:background="@drawable/widget_bg">

    <!-- Monstera plant — top-right decorative -->
    <ImageView
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_gravity="top|right"
        android:layout_marginTop="-12dp"
        android:layout_marginRight="-8dp"
        android:src="@drawable/home_plant"
        android:scaleType="fitEnd"
        android:alpha="0.45"
        android:importantForAccessibility="no" />

    <!-- Main content on top of plant -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header: branding + level badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ELED"
                android:textColor="@color/widget_text_brand"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/widget_levels"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="A1"
                android:background="@drawable/widget_badge_green"
                android:textColor="@color/widget_text_level"
                android:textSize="9sp"
                android:textStyle="bold"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp" />

        </LinearLayout>

        <!-- Center content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/widget_word"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Loading..."
                android:textColor="@color/widget_text_primary"
                android:textSize="26sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_pos_ipa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="noun  /.../"
                android:textColor="@color/widget_text_muted"
                android:textSize="11sp"
                android:textStyle="italic"
                android:layout_marginTop="2dp"
                android:maxLines="1" />

            <!-- Divider -->
            <FrameLayout
                android:layout_width="32dp"
                android:layout_height="1dp"
                android:background="@drawable/widget_divider"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/widget_translation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Waiting for data..."
                android:textColor="@color/widget_text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Footer: topic badge -->
        <TextView
            android:id="@+id/widget_topic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Topic"
            android:background="@drawable/widget_badge_peach"
            android:textColor="@color/widget_text_topic"
            android:textSize="9sp"
            android:textStyle="bold"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

</FrameLayout>
